generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  password     String
  name         String
  role         String        @default("STAFF")
  ip_address   String?
  location     String?
  last_seen    DateTime?
  access_level Int           @default(1)
  logs         AuditLog[]
  jobs         Job[]
  transactions Transaction[]
}

model RolePermission {
  role        String  @id
  permissions Json
  description String?
}

model Customer {
  cv           String              @id @default("A100001")
  name         String
  phone        String?
  address      String?
  sub_district String?
  district     String?
  province     String?
  zipcode      String?
  latitude     Float?
  longitude    Float?
  image_url    String?
  asset_units  AssetUnit[]
  inventory    CustomerInventory[]
  jobs         Job[]

  @@map("Customer")
}

model Warehouse {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  is_active    Boolean          @default(true)
  latitude     Float?
  longitude    Float?
  asset_units  AssetUnit[]      @relation("AssetUnitWarehouse")
  jobs         Job[]
  targets      Transaction[]    @relation("TargetWarehouse")
  transactions Transaction[]
  stocks       WarehouseStock[]

  @@map("Warehouse")
}

model MasterItem {
  id                   Int                 @id @default(autoincrement())
  category             String
  brand                String?
  item_name            String?
  condition            String?
  details              String?
  size                 String?
  stock_qty            Int                 @default(0)
  tracking_type        TrackingType        @default(BATCH)
  asset_units          AssetUnit[]
  customer_inventories CustomerInventory[]
  transactions         Transaction[]
  warehouse_stocks     WarehouseStock[]

  @@index([category])
  @@index([tracking_type])
  @@map("MasterItem")
}

model WarehouseStock {
  id             Int        @id @default(autoincrement())
  item_id        Int
  warehouse_id   Int
  stock_qty      Int        @default(0)
  repair_qty     Int        @default(0)
  scrap_qty      Int        @default(0)
  lost_qty       Int        @default(0)
  quarantine_qty Int        @default(0)
  transit_qty    Int        @default(0)
  item           MasterItem @relation(fields: [item_id], references: [id], onDelete: Cascade)
  warehouse      Warehouse  @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)

  @@unique([item_id, warehouse_id])
  @@index([item_id])
  @@index([warehouse_id])
  @@map("WarehouseStock")
}

model CustomerInventory {
  id           Int        @id @default(autoincrement())
  customer_cv  String
  item_id      Int
  quantity     Int        @default(0)
  last_updated DateTime   @default(now()) @updatedAt
  customer     Customer   @relation(fields: [customer_cv], references: [cv], onDelete: Cascade)
  item         MasterItem @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@unique([customer_cv, item_id])
  @@index([item_id])
  @@map("CustomerInventory")
}

model AssetUnit {
  id                   Int             @id @default(autoincrement())
  master_item_id       Int
  asset_tag            String          @unique
  serial_number        String?         @unique
  status               AssetUnitStatus @default(stock)
  current_warehouse_id Int?
  holder_customer_cv   String?
  note                 String?
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt
  current_warehouse    Warehouse?      @relation("AssetUnitWarehouse", fields: [current_warehouse_id], references: [id])
  holder_customer      Customer?       @relation(fields: [holder_customer_cv], references: [cv])
  item                 MasterItem      @relation(fields: [master_item_id], references: [id], onDelete: Cascade)

  @@index([master_item_id])
  @@index([status])
  @@index([current_warehouse_id])
  @@index([holder_customer_cv])
  @@index([status, current_warehouse_id])
  @@map("AssetUnit")
}

model Job {
  job_id            String        @id
  customer_cv       String?
  job_type          String
  operator_id       Int
  status            String
  note              String?
  created_at        DateTime      @default(now())
  delivery_by       String?
  notification_date DateTime?
  notifier          String?
  appointment_date  DateTime?
  warehouse_id      Int?
  customer          Customer?     @relation(fields: [customer_cv], references: [cv])
  operator          User          @relation(fields: [operator_id], references: [id])
  warehouse         Warehouse?    @relation(fields: [warehouse_id], references: [id])
  transactions      Transaction[]

  @@index([status])
  @@index([customer_cv])
  @@index([created_at])
  @@index([status, created_at])
  @@map("Job")
}

model Transaction {
  id               Int         @id @default(autoincrement())
  job_id           String?
  item_id          Int?
  operator_id      Int
  action_type      String
  quantity         Int
  zone_name        String?
  return_reason    String?
  cabinet_status   String?
  cancel_reason    String?
  image_url        String?
  created_at       DateTime    @default(now())
  serial_number    String?
  distance_warning String?
  lat              Float?
  lng              Float?
  delivery_by      String?
  to_warehouse_id  Int?
  warehouse_id     Int?
  note             String?
  activity_name    String?
  asset_tag        String?
  txn_no           String?
  item             MasterItem? @relation(fields: [item_id], references: [id])
  job              Job?        @relation(fields: [job_id], references: [job_id])
  operator         User        @relation(fields: [operator_id], references: [id])
  target_warehouse Warehouse?  @relation("TargetWarehouse", fields: [to_warehouse_id], references: [id])
  warehouse        Warehouse?  @relation(fields: [warehouse_id], references: [id])
  zone             Zone?       @relation(fields: [zone_name], references: [name])

  @@index([job_id])
  @@index([item_id])
  @@index([operator_id])
  @@index([created_at])
  @@index([action_type])
  @@index([asset_tag])
  @@index([job_id, created_at])
  @@index([job_id, txn_no])
  @@index([action_type, created_at])
  @@index([warehouse_id, created_at])
  @@map("Transaction")
}

model Zone {
  name         String        @id
  details      String?
  transactions Transaction[]

  @@map("Zone")
}

model SystemSetting {
  key   String @id
  value String

  @@map("SystemSetting")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  ip_address String?
  location   String?
  user_agent String?
  action     String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([created_at])
  @@map("AuditLog")
}

enum TrackingType {
  BATCH
  SERIALIZED
}

enum AssetUnitStatus {
  stock
  quarantine
  repair
  in_transit
  with_customer
  scrap
  lost
}
